#!/bin/bash
# Concept pomodoro 28 min -- 6 min 30 sec
gress() {
  work=$1

  for ((sec = work; sec > 0; sec--)); do
    full=$((barlen * sec / work))
    [ "$sec" -ne "$work" ] && full=$((full + 1))
    empty=$((barlen - full))
    if [ "$work" -eq 60 ]; then
      message=" [LWORK "
    elif [ "$work" -eq 120 ]; then
      message=" [EWORK "
    elif [ "$work" -eq 240 ]; then
      message=" [NWORK "
    elif [ "$work" -eq 480 ]; then
      message=" [HWORK "
    elif [ "$work" -eq 390 ]; then
      message=" [PAUSE "
    fi

    message="$message${sec}s]"
    messagelen=${#message}
    if [ "$full" -gt "$messagelen" ]; then
      full=$((full - messagelen))
      fs="$message"
      es=
    else
      empty=$((empty - (messagelen - full)))
      fs=${message:0:$full}
      es=${message:$full}
      full=0
    fi
    while [ "$full" -gt 0 ]; do
      fs="$fs"' '
      full=$((full - 1))
    done
    while [ "$empty" -gt 0 ]; do
      es="$es"' '
      empty=$((empty - 1))
    done

    echo -e "$fs\n$fs\n#04060a" >"$XDG_RUNTIME_DIR"/pfull
    if [ "$work" -eq 60 ]; then
      echo "#b3bf3b" >>"$XDG_RUNTIME_DIR"/pfull
    elif [ "$work" -eq 120 ]; then
      echo "#f2cf66" >>"$XDG_RUNTIME_DIR"/pfull
    elif [ "$work" -eq 240 ]; then
      echo "#d43f3f" >>"$XDG_RUNTIME_DIR"/pfull
    elif [ "$work" -eq 480 ]; then
      echo "#b07ebf" >>"$XDG_RUNTIME_DIR"/pfull
    elif [ "$work" -eq 390 ]; then
      echo "#69a1cf" >>"$XDG_RUNTIME_DIR"/pfull
    fi
    echo -e "$es\n$es" >"$XDG_RUNTIME_DIR"/pempt

    pgrep i3blocks >/dev/null && pkill -SIGRTMIN+13 i3blocks
    sleep 1
  done
  >"$XDG_RUNTIME_DIR"/pempt
}

lwork=60
ework=120
nwork=240
hwork=480
pause=390

barlen=24

mkdir -p ~/.local/state/pmdr && cp ~/.config/pmdr/skel.md ~/.local/state/pmdr/suivi.md
alacritty --class pmdr -e nvim ~/.local/state/pmdr/suivi.md &
sleep 0.2
swaymsg [con_id=$(swaymsg -t get_tree | jq -r '.. | try select(.app_id == "pmdr").id')] move scratchpad && swaymsg scratchpad show

wait

notify-send "PMDR" "Début de la session de travail..."

gress $lwork
gress $lwork
gress $ework
gress $ework
gress $ework
gress $nwork
gress $nwork
gress $hwork
gress $ework
gress $ework

swaymsg -q $(alacritty --class pmdr -e nvim ~/.local/state/pmdr/suivi.md) &
sleep 0.2
swaymsg [con_id=$(swaymsg -t get_tree | jq '.. | try select(.app_id == "pmdr").id')] move scratchpad && swaymsg scratchpad show
wait

cp ~/.local/state/pmdr/suivi.md ~/documents/pmdr_$(date +%d-%m-%Y_%H%M).md

notify-send "PMDR" "Fin de la session de travail.\nFiche de suivi $HOME/documents/pmdr_$(date +%d-%m-%Y_%H%M).md\nDébut de la pause..."

gress $pause

rm "$XDG_RUNTIME_DIR"/pfull "$XDG_RUNTIME_DIR"/pempt
pgrep i3blocks >/dev/null && pkill -SIGRTMIN+13 i3blocks

notify-send "PMDR" "Fin de la pause !\nSuper+p pour lancer un nouveau cycle."

exit 0
